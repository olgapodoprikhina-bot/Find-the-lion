<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Знайди Лева 🦁 — Puzzle Edition</title>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<style>
  :root {
    --savanna: #130e05;
    --savanna2: #1e1508;
    --dust: #f5e6c8;
    --amber: #e8a020;
    --amber-dim: rgba(232,160,32,0.18);
    --flame: #d45a1a;
    --mane: #8b4513;
    --grass: #2d3a1a;
    --sky: #1e2d3d;
    --ghost: rgba(245,230,200,0.06);
    --card: rgba(30,21,8,0.85);
    --card-hover: rgba(40,30,12,0.9);
    --border: rgba(232,160,32,0.22);
    --border-bright: rgba(232,160,32,0.45);
    --red: #c0392b;
    --green: #27ae60;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--savanna);
    color: var(--dust);
    font-family: 'Nunito', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(30,21,8,1) 0%, rgba(10,5,0,1) 100%);
    z-index: -1;
  }

  #root { position: relative; z-index: 1; }

  /* --- PUZZLE STYLES --- */
  .puzzle-container {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    margin: 1.5rem 0;
    display: grid;
    gap: 2px;
    border-radius: 12px;
    overflow: hidden;
    border: 2px solid var(--border);
    perspective: 1000px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .puzzle-piece {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .puzzle-piece.revealed {
    transform: rotateY(180deg);
  }

  .piece-front, .piece-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 2px;
  }

  .piece-front {
    background: linear-gradient(135deg, #2a1f0d 0%, #1a1508 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(232,160,32,0.1);
  }
  .piece-front::after {
    content: '🦁';
    opacity: 0.2;
    font-size: 1.2rem;
  }

  .piece-back {
    transform: rotateY(180deg);
    background-size: cover;
    background-repeat: no-repeat;
  }

  /* --- UI --- */
  .onboard { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; text-align: center; }
  .onboard-lion { font-size: 5rem; margin-bottom: 1.5rem; filter: drop-shadow(0 0 30px var(--amber)); }
  .onboard h1 { font-family: 'Playfair Display', serif; font-size: 3.5rem; color: var(--amber); margin-bottom: 1rem; }
  
  .app { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
  .app-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem; }
  
  .btn-primary {
    background: linear-gradient(135deg, var(--amber), var(--flame));
    color: #000; border: none; padding: 0.8rem 1.8rem; border-radius: 50px; font-weight: 800; cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(232,160,32,0.4); }
  
  .new-project-card { background: var(--card); border: 1px solid var(--border-bright); padding: 2rem; border-radius: 20px; width: 100%; max-width: 500px; box-shadow: 0 20px 50px rgba(0,0,0,0.8); }
  .form-group { margin-bottom: 1.2rem; display: flex; flex-direction: column; }
  .form-group label { font-size: 0.75rem; text-transform: uppercase; margin-bottom: 0.5rem; color: var(--amber); font-weight: 700; }
  input { background: rgba(0,0,0,0.4); border: 1px solid var(--border); padding: 0.9rem; color: #fff; border-radius: 10px; font-family: inherit; }
  input:focus { outline: none; border-color: var(--amber); }

  .projects-grid { display: grid; gap: 2.5rem; }
  .project-card { background: var(--card); border: 1px solid var(--border); border-radius: 28px; overflow: hidden; animation: fadeIn 0.5s ease; }
  .project-content { padding: 1.8rem; }
  
  .stages-list { margin-top: 1.5rem; }
  .stage-item { 
    display: flex; align-items: center; gap: 1rem; padding: 1rem; 
    background: rgba(255,255,255,0.04); margin-bottom: 0.6rem; border-radius: 14px; cursor: pointer;
    transition: 0.3s; border: 1px solid transparent;
  }
  .stage-item:hover { background: rgba(255,255,255,0.08); border-color: var(--border); }
  .stage-item.done { opacity: 0.5; background: rgba(0,0,0,0.2); }
  .checkbox { width: 22px; height: 22px; border: 2px solid var(--amber); border-radius: 7px; display: flex; align-items: center; justify-content: center; font-weight: 900; color: #000; }
  .stage-item.done .checkbox { background: var(--amber); }

  .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); display: flex; align-items: center; justify-content: center; z-index: 100; padding: 1rem; backdrop-filter: blur(5px); }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
</head>
<body>
<div id="root"></div>

<script type="text/babel">
const { useState, useEffect, useMemo } = React;

const PUZZLE_IMAGES = [
  "https://images.unsplash.com/photo-1546182990-dffeafbe841d?auto=format&fit=crop&q=80&w=1200",
  "https://images.unsplash.com/photo-1614027164847-1b2809eb1895?auto=format&fit=crop&q=80&w=1200",
  "https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&q=80&w=1200",
  "https://images.unsplash.com/photo-1534188753412-3e26d0d618d6?auto=format&fit=crop&q=80&w=1200",
  "https://images.unsplash.com/photo-1552423814-c4980564f5f5?auto=format&fit=crop&q=80&w=1200"
];

const LS_KEY = 'znaydi_leva_puzzle_v1';

function save(data) { localStorage.setItem(LS_KEY, JSON.stringify(data)); }
function load() { return JSON.parse(localStorage.getItem(LS_KEY)) || []; }

function Puzzle({ stages, imageUrl }) {
  const total = stages.length;
  const cols = Math.ceil(Math.sqrt(total * 1.77));
  const rows = Math.ceil(total / cols);
  
  // Create a stable random mapping for this project
  const pieceMapping = useMemo(() => {
    const indices = Array.from({ length: total }, (_, i) => i);
    // Fisher-Yates shuffle
    for (let i = indices.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [indices[i], indices[j]] = [indices[j], indices[i]];
    }
    return indices;
  }, [total]);

  return (
    <div className="puzzle-container" style={{ 
      gridTemplateColumns: `repeat(${cols}, 1fr)`,
      gridTemplateRows: `repeat(${rows}, 1fr)` 
    }}>
      {Array.from({ length: total }).map((_, idx) => {
        const stageIndexForThisPiece = pieceMapping.indexOf(idx);
        const isRevealed = stages[stageIndexForThisPiece]?.done;

        const r = Math.floor(idx / cols);
        const c = idx % cols;
        const posX = cols > 1 ? (c / (cols - 1)) * 100 : 0;
        const posY = rows > 1 ? (r / (rows - 1)) * 100 : 0;

        return (
          <div key={idx} className={`puzzle-piece ${isRevealed ? 'revealed' : ''}`}>
            <div className="piece-front"></div>
            <div className="piece-back" style={{
              backgroundImage: `url(${imageUrl})`,
              backgroundPosition: `${posX}% ${posY}%`,
              backgroundSize: `${cols * 100}% ${rows * 100}%`
            }}></div>
          </div>
        );
      })}
    </div>
  );
}

function App() {
  const [projects, setProjects] = useState(load);
  const [showForm, setShowForm] = useState(false);
  const [onboarded, setOnboarded] = useState(() => !!localStorage.getItem('onboarded'));

  const [name, setName] = useState('');
  const [date, setDate] = useState('');
  const [tempStages, setTempStages] = useState(['', '', '']);

  const handleAddProject = () => {
    const validStages = tempStages.filter(s => s.trim() !== '');
    if (!name || validStages.length === 0) return;
    
    const newProject = {
      id: Date.now(),
      name,
      deadline: date,
      imageUrl: PUZZLE_IMAGES[Math.floor(Math.random() * PUZZLE_IMAGES.length)],
      stages: validStages.map((text, i) => ({
        id: i,
        text,
        done: false
      }))
    };

    const updated = [newProject, ...projects];
    setProjects(updated);
    save(updated);
    setShowForm(false);
    setName(''); setTempStages(['','','']); setDate('');
  };

  const toggleStage = (projId, stageId) => {
    const updated = projects.map(p => {
      if (p.id !== projId) return p;
      return {
        ...p,
        stages: p.stages.map(s => s.id === stageId ? { ...s, done: !s.done } : s)
      };
    });
    setProjects(updated);
    save(updated);
  };

  if (!onboarded) {
    return (
      <div className="onboard">
        <div className="onboard-lion">🦁</div>
        <h1>Знайди Лева</h1>
        <p>Перетвори рутину на полювання. Виконуй завдання — збирай пазл.</p>
        <button className="btn-primary" style={{marginTop:'2.5rem'}} onClick={() => { setOnboarded(true); localStorage.setItem('onboarded', 't'); }}>
          Розпочати
        </button>
      </div>
    );
  }

  return (
    <div className="app">
      <header className="app-header">
        <h2 style={{fontFamily:'Playfair Display', fontSize:'1.8rem', color:'var(--amber)'}}>🦁 Знайди Лева</h2>
        <button className="btn-primary" onClick={() => setShowForm(true)}>+ Новий проект</button>
      </header>

      {showForm && (
        <div className="overlay" onClick={(e) => e.target.className === 'overlay' && setShowForm(false)}>
          <div className="new-project-card">
            <h3 style={{marginBottom:'1.5rem', fontFamily:'Playfair Display', fontSize:'1.5rem'}}>Створити проект</h3>
            <div className="form-group">
              <label>Назва</label>
              <input value={name} onChange={e => setName(e.target.value)} placeholder="Напр: Дизайн колекції" />
            </div>
            <div className="form-group">
              <label>Дедлайн</label>
              <input type="date" value={date} onChange={e => setDate(e.target.value)} />
            </div>
            <div className="form-group">
              <label>Етапи (кількість = частини пазлу)</label>
              {tempStages.map((s, i) => (
                <input 
                  key={i} 
                  style={{marginBottom: '8px'}}
                  value={s} 
                  onChange={e => {
                    const next = [...tempStages];
                    next[i] = e.target.value;
                    setTempStages(next);
                  }}
                  placeholder={`Завдання ${i+1}`}
                />
              ))}
              <button onClick={() => setTempStages([...tempStages, ''])} style={{background:'none', border:'1px dashed var(--border)', color:'var(--amber)', padding:'8px', cursor:'pointer', marginTop:'5px', borderRadius:'8px'}}>
                + Додати ще етап
              </button>
            </div>
            <div style={{display:'flex', gap:'1rem', marginTop:'2rem'}}>
              <button className="btn-primary" onClick={handleAddProject} style={{flex:1}}>Створити</button>
              <button className="btn-primary" style={{background:'none', color:'#fff', border:'1px solid var(--border)', flex:1}} onClick={() => setShowForm(false)}>Назад</button>
            </div>
          </div>
        </div>
      )}

      <div className="projects-grid">
        {projects.length === 0 && (
          <div style={{textAlign:'center', opacity:0.4, marginTop:'4rem'}}>
            <p>У вас поки немає активних полів полювання.</p>
            <p>Створіть свій перший проект!</p>
          </div>
        )}
        {projects.map(p => (
          <div key={p.id} className="project-card">
            <div className="project-content">
              <div style={{display:'flex', justifyContent:'space-between', alignItems:'flex-start', marginBottom:'0.5rem'}}>
                <div>
                  <h3 style={{fontSize:'1.4rem', marginBottom:'0.2rem'}}>{p.name}</h3>
                  {p.deadline && <p style={{fontSize:'0.8rem', opacity:0.6}}>📅 До: {p.deadline}</p>}
                </div>
                <button 
                  onClick={() => { if(confirm('Видалити проект?')) { const up = projects.filter(pr => pr.id !== p.id); setProjects(up); save(up); } }}
                  style={{background:'none', border:'none', color:'rgba(255,255,255,0.2)', cursor:'pointer', fontSize:'1.2rem'}}
                >✕</button>
              </div>
              
              <Puzzle stages={p.stages} imageUrl={p.imageUrl} />

              <div className="stages-list">
                {p.stages.map(s => (
                  <div key={s.id} className={`stage-item ${s.done ? 'done' : ''}`} onClick={() => toggleStage(p.id, s.id)}>
                    <div className="checkbox">{s.done && '✓'}</div>
                    <span style={{textDecoration: s.done ? 'line-through' : 'none'}}>{s.text}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
